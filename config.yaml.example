server:
  port: ":8082"
  gin_log: true
  read_timeout: 15s
  write_timeout: 15s
  worker_count: 4                # 并发执行流水线的 Worker 协程数量
  sandbox_dir: "./workspace"     # 流水线代码克隆与执行命令的本地沙箱目录

auth:
  jwt_secret: "please-change-this-jwt-secret-in-production-environments-123456"
  password_login_enabled: true

pipeline_system:
  get_pipeline_url: "http://192.168.56.18:8080/api/external/pipeline"
  get_execution_plan_url: "http://192.168.56.18:8080/api/external/execution-plans"
  copy_checker_task_url: "http://192.168.56.18:8080/api/external/copy-checker-task"
  checker_task_template_id: "template_task_id"
  repo_auth_check_url: "http://192.168.56.18:8080/api/external/repo-auth-check"
  repo_credential_check_url: "http://192.168.56.18:8080/api/external/repo-credential-check"

code_bench:
  api_url: "http://192.168.56.18:8000"
